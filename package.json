{
  "name": "@appdna-ai/react-native-sdk",
  "version": "1.0.8",
  "appdna_feature_parity": "1.0.70",
  "description": "AppDNA SDK for React Native — analytics, experiments, paywalls, surveys, and more.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./lib/typescript/src/index.d.ts",
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "NOTICE.md",
    "src",
    "lib",
    "ios",
    "android",
    "app.plugin.js",
    "appdna-sdk-react-native.podspec",
    "!android/build",
    "!android/.gradle",
    "!ios/build",
    "!**/__tests__",
    "!**/*.test.ts",
    "!**/.*"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prepack": "bob build"
  },
  "keywords": [
    "react-native",
    "analytics",
    "sdk",
    "appdna"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@react-native/babel-preset": "^0.76.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/react": "^18.2.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react": "18.3.1",
    "react-native": "0.76.4",
    "react-native-builder-bob": "^0.30.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.0.0"
  },
  "codegenConfig": {
    "name": "RNAppdnaSpec",
    "type": "all",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.appdna.rn"
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
