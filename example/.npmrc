# SPEC-070-B P1 — install the `file:..` SDK dependency as a REAL directory, not a symlink.
#
# Default npm behaviour for a `file:` path is to symlink it into node_modules. Because the SDK the
# example depends on is its own PARENT (`file:..`), that symlink points at a directory whose tree
# contains this `example/`, so `node_modules/@appdna-ai/react-native-sdk/example/node_modules/...`
# is an infinite filesystem cycle. React Native's autolinking (`use_native_modules!` on iOS, the
# `react-native config` walk on Android) traverses that tree and never returns — `pod install`
# hangs on line 20 of the Podfile with no output.
#
# `install-links` makes npm PACK the file: dependency and extract it as a plain directory holding
# only the package's `files` allowlist (ios/, android/, the podspec) — no example/, no cycle. It is
# npm's own mechanism for consuming a local package as if it were published.
install-links=true

# The pack that install-links performs would otherwise run the SDK's `prepack` (`bob build`), which
# needs the SDK's own devDependencies — not installed on a build machine. The NATIVE compile needs
# ios/ + android/ source, not the bob-built JS lib, so skip lifecycle scripts. The example itself has
# no install script that the pod-install + xcodebuild flow depends on.
ignore-scripts=true
