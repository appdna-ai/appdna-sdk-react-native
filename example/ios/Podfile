# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# SPEC-070-B P1 / D-q1. The core pod requires iOS 16 (AppDNASDK.podspec:15); RN's
# `min_ios_version_supported` is lower, and CocoaPods resolves the FLOOR, not the max.
platform :ios, '16.0'

# CocoaPods' usage stats are sent SYNCHRONOUSLY at the end of `pod install`. The Flutter example
# disables them for the same reason: on a slow route to the stats endpoint they add minutes to
# every install for no benefit to anyone here.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

prepare_react_native_project!

target 'AppdnaExample' do
  config = use_native_modules!

  # SPEC-070-B P1 on-branch override, mirroring the Flutter example's APPDNA_IOS_SDK_PATH: build
  # against a LOCAL iOS SDK so an UNPUBLISHED native (1.0.70) can be compile-verified before
  # release. Unset in CI/publish â†’ the registry pod named by the wrapper's podspec is used.
  #
  # Declared BEFORE use_native_modules!'s podspec dependency is resolved, so the local spec wins.
  local_ios_sdk = ENV['APPDNA_IOS_SDK_PATH']
  if local_ios_sdk && !local_ios_sdk.empty?
    pod 'AppDNASDK', :path => local_ios_sdk
  end

  # SPEC-070-B P1 / D-q1 â€” Firebase's LINKAGE, established by building rather than by reasoning.
  #
  # `AppDNASDK` depends on FirebaseFirestore, a Swift pod. RN links pods as static LIBRARIES by
  # default, and CocoaPods then refuses: `FirebaseFirestoreInternal` "does not define modules".
  #
  # Three configurations were tried on the same machine, against the same pod graph:
  #
  #   1. static libraries + `use_modular_headers!` â€” CocoaPods must synthesise a module map for
  #      every ObjC pod in the graph. Never finished; killed at 3600s with the download cache flat.
  #   2. `use_frameworks! :linkage => :static` â€” wedged for 1800s inside
  #      `Installing target BoringSSL-GRPC`, Firestore's gRPC dependency, emitting nothing.
  #   3. `use_frameworks!` (dynamic) + `use_modular_headers!` â€” what the Flutter example in this
  #      repo has always used, pulling the identical Firestore â†’ gRPC â†’ BoringSSL chain, and what
  #      installs on this hardware in minutes.
  #
  # So: (3). The failures above are recorded because each looks reasonable on paper, and the only
  # thing that distinguishes them is having run them.
  #
  # `app.plugin.js` sets `ios.useFrameworks: 'dynamic'` to match â€” the bare Podfile and the Expo
  # plugin must not disagree about linkage, or the example builds a target no Expo consumer can
  # reproduce.
  use_frameworks!
  use_modular_headers!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Every pod, not just ours: a transitive dep left at iOS 13 fails to link against a 16.0 app.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      end
    end
  end
end
